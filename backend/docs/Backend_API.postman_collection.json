{
  "info": {
    "_postman_id": "backend-api-collection",
    "name": "Backend API - Pet Adoption System",
    "description": "Colección completa de endpoints del Backend (Puerto 8081)\n\nBase URL: http://localhost:8081\n\nAutenticación: JWT Bearer Token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{backend_url}}/login",
              "host": ["{{backend_url}}"],
              "path": ["login"]
            },
            "description": "Obtiene token JWT para autenticarse en endpoints protegidos"
          },
          "response": []
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"recepcionista01\",\n  \"email\": \"recep@duocvet.cl\",\n  \"password\": \"recep123\"\n}"
            },
            "url": {
              "raw": "{{backend_url}}/users/register",
              "host": ["{{backend_url}}"],
              "path": ["users", "register"]
            },
            "description": "Registra un nuevo usuario con contraseña hasheada en BCrypt"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Mascotas (Pets)",
      "item": [
        {
          "name": "Get All Pets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backend_url}}/pets",
              "host": ["{{backend_url}}"],
              "path": ["pets"]
            },
            "description": "Lista todas las mascotas (público, sin autenticación)"
          },
          "response": []
        },
        {
          "name": "Get Pet by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backend_url}}/pets/1",
              "host": ["{{backend_url}}"],
              "path": ["pets", "1"]
            },
            "description": "Obtiene mascota por ID"
          },
          "response": []
        },
        {
          "name": "Get Available Pets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backend_url}}/pets/available",
              "host": ["{{backend_url}}"],
              "path": ["pets", "available"]
            },
            "description": "Lista mascotas disponibles para adopción (status='available')"
          },
          "response": []
        },
        {
          "name": "Search Pets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backend_url}}/pets/search?species=Perro&gender=Macho&location=Santiago&status=available",
              "host": ["{{backend_url}}"],
              "path": ["pets", "search"],
              "query": [
                {
                  "key": "species",
                  "value": "Perro",
                  "disabled": false
                },
                {
                  "key": "gender",
                  "value": "Macho",
                  "disabled": false
                },
                {
                  "key": "location",
                  "value": "Santiago",
                  "disabled": false
                },
                {
                  "key": "status",
                  "value": "available",
                  "disabled": false
                }
              ]
            },
            "description": "Busca mascotas por criterios (todos opcionales)\n- species: Perro, Gato, etc.\n- gender: Macho, Hembra\n- location: Ciudad\n- age: Edad exacta\n- status: available, adopted"
          },
          "response": []
        },
        {
          "name": "Create Pet",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rocko\",\n  \"species\": \"Perro\",\n  \"breed\": \"Labrador\",\n  \"age\": 2,\n  \"gender\": \"Macho\",\n  \"location\": \"Valparaiso\",\n  \"photos\": [\n    \"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6e/Golde33443.jpg/1024px-Golde33443.jpg\"\n  ]\n}"
            },
            "url": {
              "raw": "{{backend_url}}/pets",
              "host": ["{{backend_url}}"],
              "path": ["pets"]
            },
            "description": "Crea nueva mascota (requiere autenticación)"
          },
          "response": []
        },
        {
          "name": "Update Pet",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"adopted\",\n  \"location\": \"Santiago\"\n}"
            },
            "url": {
              "raw": "{{backend_url}}/pets/1",
              "host": ["{{backend_url}}"],
              "path": ["pets", "1"]
            },
            "description": "Actualiza mascota (requiere autenticación)"
          },
          "response": []
        },
        {
          "name": "Delete Pet",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{backend_url}}/pets/1",
              "host": ["{{backend_url}}"],
              "path": ["pets", "1"]
            },
            "description": "Elimina mascota (requiere autenticación)"
          },
          "response": []
        }
      ]
