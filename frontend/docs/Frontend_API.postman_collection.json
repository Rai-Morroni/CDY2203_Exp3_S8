{
  "info": {
    "_postman_id": "frontend-api-collection",
    "name": "Frontend API - Pet Adoption System",
    "description": "Colección completa de endpoints del Frontend (Puerto 8080)\n\nBase URL: http://localhost:8080\n\nEl Frontend actúa como proxy hacia el Backend\nAutenticación: JWT en Cookie HTTP-only",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{frontend_url}}/api/auth/login",
              "host": ["{{frontend_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Autentica usuario y retorna token JWT en cookie HTTP-only\n\nRespuesta: 204 No Content (con cookie de autenticación en Set-Cookie header)"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{frontend_url}}/api/auth/logout",
              "host": ["{{frontend_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Elimina la cookie de autenticación (logout)"
          },
          "response": []
        },
        {
          "name": "Check Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{frontend_url}}/api/auth/session",
              "host": ["{{frontend_url}}"],
              "path": ["api", "auth", "session"]
            },
            "description": "Verifica si hay sesión activa\n\nRespuesta:\n- 204 No Content: Sesión activa\n- 401 Unauthorized: Sin sesión"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Mascotas (Pets)",
      "item": [
        {
          "name": "Get All Pets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{frontend_url}}/api/pets",
              "host": ["{{frontend_url}}"],
              "path": ["api", "pets"]
            },
            "description": "Lista todas las mascotas (público, sin autenticación)"
          },
          "response": []
        },
        {
          "name": "Get Available Pets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{frontend_url}}/api/pets/available",
              "host": ["{{frontend_url}}"],
              "path": ["api", "pets", "available"]
            },
            "description": "Lista mascotas disponibles para adopción"
          },
          "response": []
        },
        {
          "name": "Search Pets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{frontend_url}}/api/pets/search?species=Perro&gender=Macho&location=Santiago",
              "host": ["{{frontend_url}}"],
              "path": ["api", "pets", "search"],
              "query": [
                {
                  "key": "species",
                  "value": "Perro",
                  "disabled": false
                },
                {
                  "key": "gender",
                  "value": "Macho",
                  "disabled": false
                },
                {
                  "key": "location",
                  "value": "Santiago",
                  "disabled": false
                },
                {
                  "key": "age",
                  "value": "3",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "available",
                  "disabled": true
                }
              ]
            },
            "description": "Busca mascotas por criterios (todos opcionales)\n\nEl Frontend actúa como proxy y reenvía al Backend"
          },
          "response": []
        },
        {
          "name": "Create Pet",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rocko\",\n  \"species\": \"Perro\",\n  \"breed\": \"Labrador\",\n  \"age\": 2,\n  \"gender\": \"Macho\",\n  \"location\": \"Valparaiso\",\n  \"photos\": [\n    \"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6e/Golde33443.jpg/1024px-Golde33443.jpg\"\n  ]\n}"
            },
            "url": {
              "raw": "{{frontend_url}}/api/pets",
              "host": ["{{frontend_url}}"],
              "path": ["api", "pets"]
            },
            "description": "Crea nueva mascota (requiere autenticación)\n\nLa cookie debe estar automáticamente incluida por Postman"
          },
          "response": []
        },
        {
          "name": "Update Pet",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"adopted\",\n  \"location\": \"Santiago\"\n}"
            },
            "url": {
              "raw": "{{frontend_url}}/api/pets/1",
              "host": ["{{frontend_url}}"],
              "path": ["api", "pets", "1"]
            },
            "description": "Actualiza mascota (requiere autenticación)"
          },
          "response": []
        },
        {
          "name": "Delete Pet",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{frontend_url}}/api/pets/1",
              "host": ["{{frontend_url}}"],
              "path": ["api", "pets", "1"]
            },
            "description": "Elimina mascota (requiere autenticación)"
          },
          "response": []
        }
      ]
    },
